# URL utama website untuk metadata, sitemap, robots, dan canonical URL.
NEXT_PUBLIC_SITE_URL=https://zimeira.duazreklame.my.id

# Ganti sebelum deploy. Jangan gunakan password development.
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSCODE=ganti-dengan-password-admin-yang-kuat

# Secret acak minimal 32 karakter untuk cookie login admin.
CMS_AUTH_SECRET=ganti-dengan-secret-random-panjang-minimal-32-karakter

# Opsional untuk production Vercel.
# Buat Vercel Blob Store, lalu masukkan token ini agar CMS dan upload portfolio tersimpan permanen.
BLOB_READ_WRITE_TOKEN=vercel_blob_read_write_token_dari_dashboard

# Catatan:
# CMS saat ini memakai file JSON lokal dan upload ke public/uploads/portfolio.
# Jika BLOB_READ_WRITE_TOKEN tersedia, CMS otomatis memakai Vercel Blob.
